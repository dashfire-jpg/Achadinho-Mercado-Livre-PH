rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - description: string (optional)
    //   - price: number (required)
    //   - originalPrice: number (optional)
    //   - imageUrl: string (required)
    //   - affiliateLink: string (required)
    //   - platform: string (required)
    //   - category: string (required)
    //   - isHot: boolean (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "dashfire@gmail.com");
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'price', 'imageUrl', 'affiliateLink', 'platform', 'category', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.imageUrl is string && data.imageUrl.size() < 2000 &&
             data.affiliateLink is string && data.affiliateLink.size() < 2000 &&
             data.platform is string &&
             data.category is string;
    }

    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      
      // Only admin can create, update, or delete
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }
    
    // Test connection path
    match /test/connection {
      allow read: if true;
    }
  }
}
